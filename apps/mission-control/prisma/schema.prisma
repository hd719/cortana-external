generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  active
  idle
  degraded
  offline
}

enum RunStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum Severity {
  info
  warning
  critical
}

model Agent {
  id           String      @id @default(uuid())
  name         String
  role         String
  description  String?
  capabilities String?
  model        String?
  status       AgentStatus @default(active)
  healthScore  Int?
  lastSeen     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  runs         Run[]
  events       Event[]
}

model Run {
  id             String    @id @default(uuid())
  agentId        String?
  agent          Agent?    @relation(fields: [agentId], references: [id])
  jobType        String
  status         RunStatus @default(queued)
  summary        String?
  payload        Json?
  result         Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  openclawRunId  String?   @unique @map("openclaw_run_id")
  externalStatus String?   @map("external_status")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  events         Event[]
}

model Event {
  id           String   @id @default(uuid())
  agentId      String?
  agent        Agent?   @relation(fields: [agentId], references: [id])
  runId        String?
  run          Run?     @relation(fields: [runId], references: [id])
  type         String
  severity     Severity @default(info)
  message      String
  metadata     Json?
  createdAt    DateTime @default(now())
  acknowledged Boolean  @default(false)
}

model TradingRunState {
  id                  String   @id @default(uuid())
  runId               String   @unique @map("run_id")
  schemaVersion       Int      @default(1) @map("schema_version")
  strategy            String
  status              String
  createdAt           DateTime @map("created_at")
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  notifiedAt          DateTime? @map("notified_at")
  deliveryStatus      String?  @map("delivery_status")
  decision            String?
  confidence          Float?
  risk                String?
  correctionMode      Boolean? @map("correction_mode")
  buyCount            Int?     @map("buy_count")
  watchCount          Int?     @map("watch_count")
  noBuyCount          Int?     @map("no_buy_count")
  symbolsScanned      Int?     @map("symbols_scanned")
  candidatesEvaluated Int?     @map("candidates_evaluated")
  focusTicker         String?  @map("focus_ticker")
  focusAction         String?  @map("focus_action")
  focusStrategy       String?  @map("focus_strategy")
  dipBuyerBuy         String[] @default([]) @map("dip_buyer_buy")
  dipBuyerWatch       String[] @default([]) @map("dip_buyer_watch")
  dipBuyerNoBuy       String[] @default([]) @map("dip_buyer_no_buy")
  canslimBuy          String[] @default([]) @map("canslim_buy")
  canslimWatch        String[] @default([]) @map("canslim_watch")
  canslimNoBuy        String[] @default([]) @map("canslim_no_buy")
  artifactDirectory   String?  @map("artifact_directory")
  summaryPath         String?  @map("summary_path")
  messagePath         String?  @map("message_path")
  watchlistPath       String?  @map("watchlist_path")
  messagePreview      String?  @map("message_preview")
  metrics             Json?
  lastError           String?  @map("last_error")
  sourceHost          String?  @map("source_host")
  insertedAt          DateTime @default(now()) @map("inserted_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@index([completedAt(sort: Desc)])
  @@map("mc_trading_runs")
}

model WhoopWebhookEvent {
  id                    String   @id @default(uuid()) @db.Uuid
  traceId               String   @unique @map("trace_id")
  whoopUserId           String   @map("whoop_user_id")
  eventType             String   @map("event_type")
  resourceId            String   @map("resource_id")
  status                String   @default("queued")
  receivedAt            DateTime @default(now()) @map("received_at")
  processAfter          DateTime? @map("process_after")
  processingStartedAt   DateTime? @map("processing_started_at")
  processedAt           DateTime? @map("processed_at")
  attemptCount          Int      @default(0) @map("attempt_count")
  lastError             String?  @map("last_error")
  coalescedIntoTraceId  String?  @map("coalesced_into_trace_id")
  signatureValid        Boolean  @default(true) @map("signature_valid")
  payloadCompact        Json     @default("{}") @map("payload_compact")
  rawPayload            Json?    @map("raw_payload")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([status, processAfter, receivedAt])
  @@index([eventType, resourceId, receivedAt(sort: Desc)])
  @@index([receivedAt(sort: Desc)])
  @@map("whoop_webhook_events")
}

model WhoopEventAnalysis {
  id                    String   @id @default(uuid()) @db.Uuid
  traceId               String   @unique @map("trace_id")
  schemaVersion         String   @default("whoop_event_analysis.v1") @map("schema_version")
  source                String
  artifact              Json
  notificationCandidate Boolean  @default(false) @map("notification_candidate")
  notificationStatus    String   @default("no_reply") @map("notification_status")
  spartanSessionKey     String?  @map("spartan_session_key")
  telegramMessageId     String?  @map("telegram_message_id")
  notifiedAt            DateTime? @map("notified_at")
  error                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([source, createdAt(sort: Desc)])
  @@index([notificationStatus, createdAt(sort: Desc)])
  @@map("whoop_event_analysis")
}

model WhoopActivityLog {
  id           String   @id @default(uuid()) @db.Uuid
  triggerKey   String   @unique @map("trigger_key")
  source       String
  activityType String   @map("activity_type")
  resourceId   String?  @map("resource_id")
  status       String
  traceId      String?  @map("trace_id")
  analysisId   String?  @map("analysis_id") @db.Uuid
  summary      String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("whoop_activity_log")
}

model CortanaEpic {
  id          Int           @id @default(autoincrement())
  title       String
  source      String?       @map("source")
  status      String        @default("active")
  deadline    DateTime?     @map("deadline")
  createdAt   DateTime      @default(now()) @map("created_at")
  completedAt DateTime?     @map("completed_at")
  metadata    Json?         @map("metadata")
  tasks       CortanaTask[]

  @@map("cortana_epics")
}

model CortanaTask {
  id             Int           @id @default(autoincrement())
  title          String
  description    String?       @map("description")
  priority       Int           @default(3)
  status         String        @default("pending")
  dueAt          DateTime?     @map("due_at")
  remindAt       DateTime?     @map("remind_at")
  executeAt      DateTime?     @map("execute_at")
  autoExecutable Boolean       @default(false) @map("auto_executable")
  executionPlan  String?       @map("execution_plan")
  dependsOn      Int[]         @default([]) @map("depends_on") @db.Integer
  completedAt    DateTime?     @map("completed_at")
  outcome        String?       @map("outcome")
  metadata       Json?         @map("metadata")
  epicId         Int?          @map("epic_id")
  parentId       Int?          @map("parent_id")
  assignedTo     String?       @map("assigned_to")
  source         String?       @map("source")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  epic           CortanaEpic?  @relation(fields: [epicId], references: [id])
  parent         CortanaTask?  @relation("Subtasks", fields: [parentId], references: [id])
  children       CortanaTask[] @relation("Subtasks")

  @@map("cortana_tasks")
}
